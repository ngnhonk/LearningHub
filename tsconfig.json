{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",

		"moduleResolution": "bundler",
		"rootDir": "./src",
		"outDir": "dist",

		"paths": {
			"@/*": ["./src/*"]
		},

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		"types": ["vitest/globals"]
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
